generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Job {
  id            String   @id @default(cuid())
  titleAr       String   @db.VarChar(200)
  titleEn       String?  @db.VarChar(200)
  descriptionAr String   @db.Text
  category      String?  @db.VarChar(80)
  level         String?  @db.VarChar(40)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  skills        JobSkill[]
  paths         LearningPath[]
}

model Skill {
  id        String   @id @default(cuid())
  nameAr    String   @unique @db.VarChar(160)
  nameEn    String?  @db.VarChar(160)
  category  String?  @db.VarChar(80)
  createdAt DateTime @default(now())
  jobs      JobSkill[]
  courses   CourseSkill[]
}

model JobSkill {
  id         String  @id @default(cuid())
  jobId      String
  skillId    String
  importance Int     @default(3)
  job        Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill      Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@index([skillId])
}

model Company {
  id          String   @id @default(cuid())
  nameAr      String   @db.VarChar(200)
  nameEn      String?  @db.VarChar(200)
  industry    String?  @db.VarChar(80)
  website     String?  @db.VarChar(255)
  logoUrl     String?  @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())
}

model Platform {
  id      String   @id @default(cuid())
  nameAr  String   @db.VarChar(160)
  nameEn  String?  @db.VarChar(160)
  website String?  @db.VarChar(255)
  logoUrl String?  @db.VarChar(255)
  courses Course[]
}

model Course {
  id           String        @id @default(cuid())
  titleAr      String        @db.VarChar(255)
  titleEn      String?       @db.VarChar(255)
  description  String?       @db.Text
  url          String?       @db.VarChar(500)
  durationHrs  Int?
  level        String?       @db.VarChar(40)
  isFree       Boolean       @default(false)
  language     String?       @default("ar") @db.VarChar(10)
  platformId   String?
  platform     Platform?     @relation(fields: [platformId], references: [id], onDelete: SetNull)
  skills       CourseSkill[]
  paths        LearningPathCourse[]
  createdAt    DateTime      @default(now())

  @@index([platformId])
}

model CourseSkill {
  id       String @id @default(cuid())
  courseId String
  skillId  String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([courseId, skillId])
  @@index([skillId])
}

model LearningPath {
  id          String                 @id @default(cuid())
  titleAr     String                 @db.VarChar(200)
  description String?                @db.Text
  jobId       String?
  job         Job?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  courses     LearningPathCourse[]
  createdAt   DateTime               @default(now())

  @@index([jobId])
}

model LearningPathCourse {
  id       String       @id @default(cuid())
  pathId   String
  courseId String
  order    Int          @default(0)
  path     LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course   Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([pathId])
  @@index([courseId])
}

model Report {
  id              String   @id @default(cuid())
  fullName        String   @db.VarChar(150)
  jobTitle        String   @db.VarChar(200)
  employer        String?  @db.VarChar(200)
  currentSkills   String   @db.Text
  currentCourses  String?  @db.Text
  matchedJobId    String?
  data            Json
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(80)
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
