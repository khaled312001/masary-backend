{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate",
  "installCommand": "npm install --ignore-scripts && npx prisma generate",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
